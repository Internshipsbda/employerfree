{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/buttons/**",
              "components/forms/**",
              "components/surfaces/**",
              "ui_kits/freebie-tools/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Raleway))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Raleway."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|uppercase|iconLeft|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, uppercase, iconLeft."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|orange|slate|ink|wicked|solidOrange|solidBlue)$/]",
        "message": "<Badge> tone must be one of 'blue' | 'orange' | 'slate' | 'ink' | 'wicked' | 'solidOrange' | 'solidBlue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|iconLeft|iconRight|type|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, iconLeft, iconRight, type, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|accent|highlight|radius|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, accent, highlight, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:orange|blue|ink)$/]",
        "message": "<Card> accent must be one of 'orange' | 'blue' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|as|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|orange|ink)$/]",
        "message": "<Eyebrow> tone must be one of 'blue' | 'orange' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<OptionCard> doesn't accept that prop. Declared props: children, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|suffix|children|style|key|ref|className|style|children)$/]",
        "message": "<ResultPanel> doesn't accept that prop. Declared props: label, value, suffix, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScaleStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<ScaleStep> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:percent|tone|height|key|ref|className|style|children)$/]",
        "message": "<ScoreBar> doesn't accept that prop. Declared props: percent, tone, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|orange|wicked|ink)$/]",
        "message": "<ScoreBar> tone must be one of 'blue' | 'orange' | 'wicked' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|type|placeholder|value|defaultValue|onChange|required|focusTone|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, id, type, placeholder, value, defaultValue, onChange, required, focusTone."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='focusTone'] > Literal[value!=/^(?:orange|blue)$/]",
        "message": "<TextField> focusTone must be one of 'orange' | 'blue'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
